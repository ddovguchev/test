
{
  "layer": "top",
  "position": "left",
  "exclusive": true,
  "height": 0,
  "width": 40,
  "spacing": 0,
  "margin-top": 0,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": -4,
    "modules-left": ["clock"],
    "modules-center": ["niri/workspaces"],
    "modules-right": [ "tray", "mpris","pulseaudio"],
    "pulseaudio": {
    	"format": "{volume}%",
      "format-muted": "ΎΣο ",
      "on-scrool-up": "swayosd-client --output-volume +1",
      "on-scrool-down": "swayosd-client --output-volume -1",
      "on-click": "swayosd-client --output-volume mute-toggle"
    },
    "backlight": {
    "format": "{percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
    },
    "niri/workspaces": {
      "format": "{index}"
    },
    "mpris": {
	    "format": "\uee58",
    	"format-stopped": "",
    	"interval": "0.1",
      "on-click": "playerctl previous",
      "on-click-middle": "playerctl play-pause",
      "on-click-right": "playerctl next",
	    "ignored-players": ["brave"],
	    "tooltip": true,
	    "tooltip-format": "{artist} - {title}"
    },
    "clock": {
      "format": "{:%I\n%M\n%p}",
      "interval": 1,
      "tooltip-format": "{:%A %d %B %Y}"
    },
    "tray": {
    	"spacing": 12,
	    "show-passive-items": true
    },
    "battery": {
    	"format": "{capacity}%",
    	"format-charging": "{capacity}% ΎΘο",
    	"format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    	"interval": 1
    },
    "custom/d": {
        "format": "|",
        "tooltip": false
    }
}
